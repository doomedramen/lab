# Lab API Environment Variables
# Copy this file to /etc/lab/lab-api.env and configure as needed

# Environment (production, development)
LAB_ENV=production

# Server port (should match config.yaml)
LAB_SERVER_PORT=8080

# libvirt connection URI
LAB_LIBVIRT_URI=qemu:///system

# Data directory
LAB_STORAGE_DATADIR=/var/lib/lab

# JWT secret (REQUIRED - generate with: openssl rand -base64 32)
# WARNING: Change this in production!
LAB_AUTH_JWT_SECRET=change-me-in-production

# Logging level (debug, info, warn, error)
LAB_LOGGING_LEVEL=info

# Logging format (text, json)
LAB_LOGGING_FORMAT=text
