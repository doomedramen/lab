{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "generate": {
      "cache": false,
      "outputs": ["apps/api/gen/**", "apps/web/lib/gen/**"]
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "bin/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["generate"],
      "cache": false,
      "persistent": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    },
     "test:e2e:headed": {
      "dependsOn": ["generate"],
      "cache": false,
      "persistent": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    },
     "test:e2e:ui": {
      "dependsOn": ["generate"],
      "cache": false,
      "persistent": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    }
  }
}
