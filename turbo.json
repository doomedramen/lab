{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "tasks": {
    "generate": {
      "inputs": ["../../packages/proto/**/*.proto", "../../packages/proto/buf.gen.*.yaml"],
      "outputs": ["gen/**", "lib/gen/**"],
      "cache": true
    },
    "build": {
      "dependsOn": ["^build", "generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "bin/**", "out/**"]
    },
    "lint": {
      "dependsOn": ["^lint", "generate"]
    },
    "format": {
      "dependsOn": ["generate"]
    },
    "check-types": {
      "dependsOn": ["^check-types", "generate"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build", "generate"],
      "cache": true
    },
    "test:unit": {
      "dependsOn": ["generate"],
      "cache": true
    },
    "test:integration": {
      "dependsOn": ["generate"],
      "cache": true
    },
    "test:e2e": {
      "dependsOn": ["generate"],
      "cache": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    },
    "test:e2e:headed": {
      "dependsOn": ["generate"],
      "cache": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    },
    "test:e2e:ui": {
      "dependsOn": ["generate"],
      "cache": false,
      "env": ["NEXT_PUBLIC_API_URL"]
    }
  }
}
