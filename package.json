{
  "name": "lab",
  "version": "0.0.19",
  "devDependencies": {
    "@workspace/eslint-config": "workspace:*",
    "@workspace/typescript-config": "workspace:*",
    "lefthook": "^2.1.2",
    "prettier": "^3.8.1",
    "syncpack": "^14.0.0",
    "turbo": "^2.8.1",
    "typescript": "latest"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.4.1",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "prepare": "lefthook install",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo lint",
    "proto": "cd packages/proto && buf generate --template buf.gen.api.yaml",
    "proto:web": "cd packages/proto && buf generate --template buf.gen.web.yaml",
    "proto:lint": "cd packages/proto && buf lint",
    "syncpack:fix": "syncpack fix",
    "syncpack:format": "syncpack format",
    "syncpack:lint": "syncpack lint",
    "syncpack:list": "syncpack list-mismatches",
    "test": "pnpm --filter api test && pnpm --filter web test:e2e",
    "test:e2e": "turbo test:e2e",
    "test:e2e:headed": "turbo test:e2e:headed",
    "test:e2e:ui": "turbo test:e2e:ui",
    "test:unit": "pnpm --filter api test"
  }
}
